# Paper Library — Backend Environment Configuration
# Copy to .env in the project root and adjust values

# ─────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────
# The LLM endpoint used by extract_pdf_metadata.py, autofill_url.py,
# fetch_paper_url.py, and scripts/crawl_all_papers.py
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=glm-4.5-air
LLM_API_KEY=dummy

# ─────────────────────────────────────────────
# CORS Configuration (CRITICAL for distributed deployment)
# ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Must include protocol, domain, and port (if non-standard).
# Use "*" for development (allows all origins — NOT for production).
#
# Examples:
#   ALLOWED_ORIGINS=*                                          (dev — allow all)
#   ALLOWED_ORIGINS=http://192.168.1.50:5173                   (single origin)
#   ALLOWED_ORIGINS=https://papers.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=9000

# ─────────────────────────────────────────────
# Crawl4AI (optional — used by fetch_paper_url.py)
# ─────────────────────────────────────────────
# CRAWL4AI_BASE_URL=http://localhost:11235
