# Paper Library environment variables

# LLM configuration
LLM_BASE_URL=http://223.108.218.44:54001/v1
LLM_MODEL=hua-llm
LLM_API_KEY=sk-v-FMlAezr7Y9GjHKwdjdWA

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=*

# Server config
HOST=0.0.0.0
PORT=9000

# Authentication
# JWT secret (change in production to a long random string)
JWT_SECRET=change-me-in-production
