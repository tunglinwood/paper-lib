LDAP_ENABLED=true
LDAP_URL=ldaps://HUACNSDC003.HUA.COM:636
LDAP_DOMAIN=huamedicine.com
# Set to true to actually verify the LDAPS certificate (recommended in production)
LDAP_VERIFY_SSL=false
